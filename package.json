{
  "name": "game-collector",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @game-collector/backend\" \"npm run dev -w @game-collector/frontend\"",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "prisma": "^5.20.0",
    "typescript": "^5.6.2",
    "@types/node": "^22.7.4"
  }
}
